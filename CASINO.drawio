        <mxCell id="FxiioPfbfOmZfcmro828-74" parent="1" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fixedSize=1;align=center;" value="&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Mostrar&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;Indicaciones:&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;Se le entregarán 2 cartas&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;a usted y 2 al crupier, si&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;sus cartas suman más de&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;21, pierde automáticamente,&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;si no, puede robar una carta&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;del mazo para llegar lo más&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;cerca posible. Al final, cuando&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;decida plantarse, tanto el&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;crupier como usted&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;mostrarán sus cartas, el que&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;se acerque más a 21 (o&amp;nbsp;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;tenga 21) gana.&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;text-align: justify;&quot;&gt;¿Desea jugar? (S/N)&lt;/div&gt;" vertex="1">
